# Git attributes for consistent line endings and diff behavior
# https://git-scm.com/docs/gitattributes

# Auto-detect text files and normalize line endings
* text=auto

# Force Unix line endings for shell scripts
*.sh text eol=lf

# Force Unix line endings for TypeScript/JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Force Unix line endings for config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.mdx text eol=lf

# CSS/styling
*.css text eol=lf
*.scss text eol=lf

# Binary files (don't normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary

# Beads merge driver
# Use `br` merge strategy for beads JSONL files
.beads/issues.jsonl merge=beads

# Lock files - use union merge to reduce conflicts
bun.lockb binary
package-lock.json merge=union
pnpm-lock.yaml merge=union

# Generated files - mark as generated for GitHub
# These won't count toward PR stats
out/** linguist-generated=true
.next/** linguist-generated=true
node_modules/** linguist-generated=true
